# ============================================================
# nba-polymarket-predictor — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git — it is in .gitignore.
# ============================================================

# Polymarket CLOB API base URL (no auth needed for market data reads)
POLYMARKET_BASE_URL=https://clob.polymarket.com

# --- Only needed if you want to place orders on Polymarket ---
# Your Polygon wallet private key (export from MetaMask)
POLYMARKET_PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

# L2 API credentials — run scripts/generate_creds.py once to get these
POLYMARKET_API_KEY=your-api-key-here
POLYMARKET_API_SECRET=your-api-secret-here
POLYMARKET_API_PASSPHRASE=your-api-passphrase-here

# Your Polymarket wallet address (public address)
POLYMARKET_ADDRESS=0xYOUR_WALLET_ADDRESS_HERE

# Chain ID: 137 = Polygon Mainnet
POLYMARKET_CHAIN_ID=137

# --- NBA Stats (uses free BallDontLie API — no key required) ---
NBA_API_BASE_URL=https://api.balldontlie.io/v1
